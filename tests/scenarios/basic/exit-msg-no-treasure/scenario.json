{
  "description": "При выходе из лабиринта без сокровища должно показываться сообщение, что выход найден",
  "setup": [
    {
      "type": "generate",
      "width": 8,
      "height": 8,
      "seed": 1,
      "openness": 0.5,
      "turns": true,
      "turn_actions": 1
    },
    {
      "type": "add-player",
      "name": "Alice",
      "x": 0,
      "y": 3
    },
    {
      "type": "set-turns",
      "on": true
    },
    {
      "type": "init-turns"
    }
  ],
  "script": [
    {
      "type": "move",
      "name": "Alice",
      "dir": "left",
      "expect_stdout": "[Alice]:\n\tEXIT_FOUND_WITHOUT_TREASURE"
    }
  ]
}