{
  "description": "Ход игрока заканчивается при столкновении со стеной",
  "setup": [
    {
      "type": "generate",
      "width": 8,
      "height": 8,
      "seed": 1,
      "openness": 0.5,
      "turns": true,
      "turn_actions": 3
    },
    {
      "type": "add-player",
      "name": "Alice",
      "x": 5,
      "y": 2
    },
    {
      "type": "add-player",
      "name": "Bob",
      "x": 2,
      "y": 0
    },
    {
      "type": "set-turns",
      "on": true
    },
    {
      "type": "init-turns"
    }
  ],
  "script": [
    {
      "type": "move",
      "name": "Bob",
      "dir": "right"
    },
    {
      "type": "move",
      "name": "Bob",
      "dir": "down"
    },
    {
      "type": "move",
      "name": "Bob",
      "dir": "down"
    },
    {
      "type": "move",
      "name": "Bob",
      "dir": "down",
      "expect_stdout": "[Bob]:\n\tMOVED:right\n[Bob]:\n\tINNER_WALL_CRASH:down\n[Bob]:\n\tNOT_YOUR_MOVE\n[Bob]:\n\tNOT_YOUR_MOVE"
    }
  ]
}