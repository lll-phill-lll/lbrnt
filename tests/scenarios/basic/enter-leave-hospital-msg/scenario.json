{
  "description": "При входе/выходе из больницы должно быть соответствующее сообщение",
  "setup": [
    {
      "type": "generate",
      "width": 8,
      "height": 8,
      "seed": 42,
      "openness": 0.5,
      "turns": false,
      "turn_actions": 1
    },
    {
      "type": "add-player",
      "name": "alice",
      "x": 4,
      "y": 5
    },
    {
      "type": "set-turns",
      "on": true
    },
    {
      "type": "init-turns"
    }
  ],
  "script": [
    {
      "type": "move",
      "name": "alice",
      "dir": "down"
    },
    {
      "type": "move",
      "name": "alice",
      "dir": "up",
      "expect_stdout": "[alice]:\n\tПрошёл вниз\n\tВы нашли больницу.\n[alice]:\n\tПрошёл вверх\n\tВы покинули больницу."
    }
  ]
}