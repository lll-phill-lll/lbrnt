{
  "description": "При входе/выходе из больницы должно быть соответствующее сообщение",
  "setup": [
    {
      "type": "generate",
      "width": 8,
      "height": 8,
      "seed": 42,
      "openness": 0.5,
      "turns": true,
      "turn_actions": 1
    },
    {
      "type": "add-player",
      "name": "Alice",
      "x": 0,
      "y": 4
    },
    {
      "type": "set-turns",
      "on": true
    },
    {
      "type": "init-turns"
    }
  ],
  "script": [
    {
      "type": "move",
      "name": "Alice",
      "dir": "down"
    },
    {
      "type": "move",
      "name": "Alice",
      "dir": "up",
      "expect_stdout": "[Alice]:\n\tMOVED:down\n\tHOSPITAL_ENTER\n[Alice]:\n\tMOVED:up\n\tHOSPITAL_EXIT"
    }
  ]
}