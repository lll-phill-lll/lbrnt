    {
      "type": "move",
      "name": "Alice",
      "dir": "right"
    },
    {
      "type": "move",
      "name": "Alice",
      "dir": "down"
    },
    {
      "type": "move",
      "name": "Alice",
      "dir": "down",
      "expect_stdout": "[Alice]:\n\tMOVED:вниз\n[Alice]:\n\tMOVED:вправо\n[Alice]:\n\tMOVED:вправо\n[Alice]:\n\tNOT_YOUR_MOVE\n[Alice]:\n\tNOT_YOUR_MOVE"
